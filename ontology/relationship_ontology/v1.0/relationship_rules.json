      "comparison_direction": "same_direction",
      "scope_comparison": "overlapping_scope_requires_review",
      "severity": "warning",
      "action": "require_human_review",
      "description": "Overlapping SUPPORTS and CONFLICTS_WITH assertions for the same direction require human reconciliation."
    },
