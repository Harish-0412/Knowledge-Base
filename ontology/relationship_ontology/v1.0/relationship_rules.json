      "description": "The same directed entity pair, scope and canonical conditions cannot have approved COMPATIBLE_WITH and CONFLICTS_WITH assertions."
    },
    {
      "constraint_id": "CPC-002-SUPPORTS-CONFLICT",
      "relationship_types": [
        "SUPPORTS",
        "CONFLICTS_WITH"
