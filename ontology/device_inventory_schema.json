{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Device Inventory Ontology Schema",
  "description": "Ontology definitions and property validation rules for Devices, ComponentInstances, and their relationships.",
  "type": "object",
  "properties": {
    "devices": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Device"
      }
    },
    "component_instances": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ComponentInstance"
      }
    },
    "relationships": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Relationship"
      }
    }
  },
  "required": [
    "devices",
    "component_instances",
    "relationships"
  ],
  "$defs": {
    "Device": {
      "type": "object",
      "description": "A computing endpoint or physical host in the endpoint inventory.",
      "required": [
        "device_id",
        "hostname",
        "vendor",
        "model",
        "os_name",
        "os_version",
        "serial_number",
        "last_seen"
      ],
      "properties": {
        "device_id": {
          "type": "string",
          "description": "Unique identifier for the device"
        },
        "hostname": {
          "type": "string",
          "description": "System hostname of the device"
        },
        "vendor": {
          "type": "string",
          "description": "Hardware or virtualization platform vendor"
        },
        "model": {
          "type": "string",
          "description": "Model of the device"
        },
        "os_name": {
          "type": "string",
          "description": "Name of the operating system installed on the device"
        },
        "os_version": {
          "type": "string",
          "description": "Version or build identifier of the operating system"
        },
        "serial_number": {
          "type": "string",
          "description": "Serial number of the hardware"
        },
        "last_seen": {
          "type": "string",
          "description": "ISO 8601 timestamp representing the last active communication check"
        }
      }
    },
    "ComponentInstance": {
      "type": "object",
      "description": "A software, firmware, or agent component instance detected on a device.",
      "required": [
        "component_instance_id",
        "component_type",
        "component_name",
        "component_family",
        "vendor",
        "version_raw",
        "version_normalized",
        "status",
        "install_date",
        "last_updated_at"
      ],
      "properties": {
        "component_instance_id": {
          "type": "string",
          "description": "Unique identifier for the component instance"
        },
        "component_type": {
          "type": "string",
          "description": "Categorized node type (e.g. Firmware, OS, Driver, SecurityComponent, Agent, ManagementTool)"
        },
        "component_name": {
          "type": "string",
          "description": "Friendly name of the component instance"
        },
        "component_family": {
          "type": "string",
          "description": "Product family name of the component"
        },
        "vendor": {
          "type": "string",
          "description": "Developer or vendor of the component"
        },
        "version_raw": {
          "type": "string",
          "description": "Raw version string reported by the host"
        },
        "version_normalized": {
          "type": "string",
          "description": "Standardized or normalized version string"
        },
        "status": {
          "type": "string",
          "description": "Current status of the component instance"
        },
        "install_date": {
          "type": "string",
          "description": "ISO 8601 timestamp of component installation"
        },
        "last_updated_at": {
          "type": "string",
          "description": "ISO 8601 timestamp of last modification"
        }
      }
    },
    "Relationship": {
      "type": "object",
      "description": "A semantic graph relationship type connecting device and component instances.",
      "required": [
        "source",
        "relationship",
        "target"
      ],
      "properties": {
        "source": {
          "type": "string",
          "description": "The unique ID of the source node (typically the device_id or component_instance_id)"
        },
        "relationship": {
          "type": "string",
          "enum": [
            "HAS_COMPONENT",
            "USES",
            "RUNS_AGENT",
            "USES_MANAGEMENT_TOOL"
          ],
          "description": "The type of the relationship"
        },
        "target": {
          "type": "string",
          "description": "The unique ID of the target node (typically the component_instance_id or device_id)"
        }
      }
    }
  }
}
