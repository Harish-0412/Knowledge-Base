APP_NAME=CompatIQ Document Intelligence Service
APP_ENV=development
APP_DEBUG=true
FASTAPI_BASE_URL=http://127.0.0.1:8000
VITE_API_BASE_URL=http://127.0.0.1:8000

DATABASE_URL=postgresql+psycopg://compatiq:compatiq@localhost:55432/compatiq_docintel

UPLOAD_DIR=storage/uploads
EXTRACTED_DIR=storage/extracted
EXPORT_DIR=storage/exports

LLM_PROVIDER=ollama
USE_MOCK_LLM=true
ALLOW_MOCK_LLM_RULE_EXTRACTION=false
USE_MOCK_OCR=false
ENABLE_DOCLING=false
DOCLING_ENABLED=false
PREFERRED_PARSER=docling
DOCLING_TABLE_STRUCTURE=true
DOCLING_TABLE_MODE=accurate
DOCLING_OCR_ENABLED=false
ENABLE_CHANDRA_OCR=false
CHANDRA_OCR_ENABLED=false
PYMUPDF_FALLBACK_ENABLED=true
CHANDRA_API_URL=
CHANDRA_TIMEOUT_SECONDS=120
LLM_JSON_REPAIR_RETRY=false
DEBUG_EXTRACTOR_COMPARISON=false
SEND_MEDIUM_LIKELIHOOD_CHUNKS=true
DEBUG_STORE_REJECTED_CHUNKS=false
CHUNKER_MODE=docling_hybrid_plus_compatiq
HYBRID_CHUNKER_MAX_TOKENS=800
HYBRID_CHUNKER_MERGE_PEERS=true
HYBRID_CHUNKER_REPEAT_TABLE_HEADERS=true
DOCLING_SAVE_DOCUMENT_JSON=true
DOCLING_SAVE_MARKDOWN=true
DOCLING_SAVE_HYBRID_CHUNKS=true
ENABLE_LLM_ZONE_CLASSIFICATION=false
EXTRACTION_PIPELINE_MODE=processing_lanes
ENABLE_DETERMINISTIC_TABLE_EXTRACTION=true
ENABLE_LLM_PROSE_EXTRACTION=true
ENABLE_LLM_TABLE_EXTRACTION=false
QUALITY_GATE_STRICT=false
EXPORT_PIPELINE_DEBUG_FILES=true

OLLAMA_BASE_URL=https://ollama.com
OLLAMA_GENERATE_PATH=/api/generate
OLLAMA_API_KEY=
OLLAMA_MODEL=gemma4:31b
OLLAMA_TIMEOUT_SECONDS=90
ASSISTANT_OLLAMA_MODEL=llama3.2:3b
ASSISTANT_MAX_ANSWER_CHARS=1200

# Optional. Raises NVD API rate limits for live CVE enrichment.
NVD_API_KEY=
NVD_TIMEOUT_SECONDS=45

MAX_UPLOAD_MB=25
