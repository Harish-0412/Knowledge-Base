    {
      "relationship_name": "HAS_INVENTORY_SNAPSHOT",
      "description": "Connects a Device to the InventorySnapshot in which the device state was observed.",
      "source_types": ["Device"],
      "target_types": ["InventorySnapshot"],
      "directionality": "source_to_target",
      "cardinality": "one_or_more_per_device",
      "inventory_semantics": "collection_provenance"
