{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Prevention types",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "prevention_id",
      "name",
      "description",
      "prevents"
    ],
    "properties": {
      "prevention_id": {
        "type": "string",
        "pattern": "^PREV-"
      },
      "name": {
        "type": "string",
        "minLength": 1
      },
      "description": {
        "type": "string",
        "minLength": 1
      },
      "prevents": {
        "type": "array",
        "minItems": 1,
        "uniqueItems": true,
        "items": {
          "type": "string",
          "pattern": "^RC-"
        }
      }
    }
  }
}
